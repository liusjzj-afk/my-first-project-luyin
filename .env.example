# 数据库
DATABASE_URL=sqlite:///./systemreq_copilot.db
# 本地 SQLite 可保持 true；生产数据库应通过 Alembic 管理并设置为 false。
AUTO_ENSURE_SCHEMA=true

# 认证上下文。development 会使用 DEFAULT_* fallback；生产可在网关鉴权后改为 trusted_headers。
AUTH_MODE=development

# LLM：兼容 OpenAI SDK 格式
LLM_API_KEY=请填写你的模型APIKey
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
SUMMARY_PROMPT_DIR=./prompts

# 阿里云智能语音交互
ALIYUN_AK=请填写阿里云AccessKeyId
ALIYUN_SK=请填写阿里云AccessKeySecret
ALIYUN_APPKEY=请填写智能语音交互AppKey
ALIYUN_REGION_ID=cn-shanghai
ALIYUN_ASR_REGION_ID=cn-shanghai

# 阿里云 OSS：用于生成 ASR 可访问的音频公网 URL
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_BUCKET=请填写Bucket名称

# 可选：如果 Bucket 绑定了公网域名，可填写该地址；否则后端会生成 2 小时 OSS 签名 URL
# ALIYUN_OSS_PUBLIC_BASE_URL=https://your-audio-domain.example.com

# 商业化任务队列。开发环境默认使用本地线程；生产建议开启 Celery + Redis。
ENABLE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 商业化媒体路径。生产默认禁用旧 Web 节点大文件 IO。
ALLOW_LEGACY_UPLOAD=false
ALLOW_LOCAL_AUDIO_STREAM=false

# 多租户默认值。正式鉴权接入后由请求上下文覆盖。
DEFAULT_TENANT_ID=public
DEFAULT_USER_ID=local-user
