# 数据库
DATABASE_URL=sqlite:///./systemreq_copilot.db

# LLM：兼容 OpenAI SDK 格式
LLM_API_KEY=请填写你的模型APIKey
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 阿里云智能语音交互
ALIYUN_AK=请填写阿里云AccessKeyId
ALIYUN_SK=请填写阿里云AccessKeySecret
ALIYUN_APPKEY=请填写智能语音交互AppKey
ALIYUN_REGION_ID=cn-shanghai
ALIYUN_ASR_REGION_ID=cn-shanghai

# 阿里云 OSS：用于生成 ASR 可访问的音频公网 URL
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_BUCKET=请填写Bucket名称

# 可选：如果 Bucket 绑定了公网域名，可填写该地址；否则后端会生成 2 小时 OSS 签名 URL
# ALIYUN_OSS_PUBLIC_BASE_URL=https://your-audio-domain.example.com
